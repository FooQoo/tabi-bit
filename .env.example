GOOGLE_GENERATIVE_AI_API_KEY=
# Google Maps Platform key with the Places API (New) + Maps Tools (Grounding Lite) enabled.
GOOGLE_PLACES_API_KEY=

# Sentry DSN — server-side init
SENTRY_DSN=
# Sentry DSN — client-side init (exposed to browser; must use VITE_ prefix)
VITE_SENTRY_DSN=
# Sentry auth token — build-time only (sourcemap upload). See .env.sentry-build-plugin
# SENTRY_AUTH_TOKEN=
